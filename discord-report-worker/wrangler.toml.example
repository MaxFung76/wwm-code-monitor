name = "wwm-report-discord-worker"
main = "src/worker.js"
compatibility_date = "2026-07-01"

[vars]
GITHUB_REPOSITORY = "Detion0115/wwm-code-monitor"
GITHUB_REF = "main"
GITHUB_WORKFLOW_ID = "sync-codes.yml"

# Optional safety limits. Leave blank to allow every guild/channel where the
# command is installed.
# ALLOWED_GUILD_ID = "123456789012345678"
# ALLOWED_CHANNEL_IDS = "123456789012345678,234567890123456789"
